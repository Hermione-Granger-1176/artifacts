{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true
  },
  "include": ["../js/**/*.js", "../apps/*/js/**/*.js", "./types/**/*.d.ts"],
  "exclude": [
    "../js/data.js",
    "../js/gallery-config.js",
    "../apps/*/js/vendor/**",
    "../node_modules"
  ]
}
