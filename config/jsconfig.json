{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "strictNullChecks": true
  },
  "include": ["../js/**/*.js"],
  "exclude": ["../js/data.js", "../js/gallery-config.js", "../node_modules"]
}
