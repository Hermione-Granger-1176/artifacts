{
  "name": "artifacts-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css && npm run lint:workflows",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:workflows": "node scripts/lint/lint-workflows.mjs",
    "test": "node --test \"tests/js/**/*.test.js\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-lines=95 --test-coverage-branches=85 --test-coverage-functions=95 --test-coverage-exclude=node_modules/** --test-coverage-exclude=tests/** --test \"tests/js/**/*.test.js\""
  },
  "devDependencies": {
    "actionlint": "2.0.6",
    "axe-core": "4.12.1",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "stylelint": "17.14.0"
  }
}
